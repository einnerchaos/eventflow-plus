# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
NODE_ENV=development
PORT=3000
APP_NAME=EventFlow+
APP_URL=http://localhost:3000

# ==========================================
# DATABASE CONFIGURATION (PostgreSQL)
# ==========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eventflow?schema=public

# Alternative explicit format:
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=eventflow

# ==========================================
# REDIS CONFIGURATION (BullMQ)
# ==========================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ==========================================
# AUTHENTICATION (JWT)
# ==========================================
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-characters-long
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# SECURITY
# ==========================================
API_KEY_SALT=your-api-key-salt-min-16-chars
BCRYPT_ROUNDS=12

# ==========================================
# QUEUE CONFIGURATION (BullMQ)
# ==========================================
QUEUE_PREFIX=bullmq
ACTION_QUEUE_NAME=action-execution
RETRY_QUEUE_NAME=retry-queue
DEAD_LETTER_QUEUE_NAME=dead-letter

# Worker concurrency
WORKER_CONCURRENCY=5

# Retry configuration
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=60000

# ==========================================
# MONITORING & OBSERVABILITY
# ==========================================
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

LOG_LEVEL=debug
LOG_FORMAT=json

# ==========================================
# EXTERNAL SERVICES
# ==========================================
# SMTP Configuration (for SEND_EMAIL action)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=EventFlow+ <noreply@eventflow.com>

# Webhook defaults
WEBHOOK_TIMEOUT_MS=30000
WEBHOOK_MAX_REDIRECTS=5

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_IDEMPOTENCY=true
ENABLE_RETRY=true
ENABLE_DEAD_LETTER=true
ENABLE_EXECUTION_HISTORY=true

# ==========================================
# DEVELOPMENT
# ==========================================
SWAGGER_ENABLED=true
# Optional future: Bull Board UI (not wired in current codebase)
# BULL_BOARD_ENABLED=false
# BULL_BOARD_PATH=/admin/queues
