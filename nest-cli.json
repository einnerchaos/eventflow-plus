{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "tsconfig.json",
    "assets": [
      {
        "include": "../prisma/**/*",
        "outDir": "dist/prisma"
      },
      {
        "include": "../docs/**/*",
        "outDir": "dist/docs"
      }
    ],
    "watchAssets": true
  },
  "projects": {
    "eventflow-plus": {
      "type": "application",
      "root": ".",
      "entryFile": "main",
      "sourceRoot": "src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json"
      }
    }
  }
}
