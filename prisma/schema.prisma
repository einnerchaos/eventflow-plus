// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// USER & AUTHENTICATION
// ==========================================

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  role          UserRole @default(ADMIN)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  lastLoginAt   DateTime? @map("last_login_at")

  // Relations
  auditLogs     AuditLog[]
  sources       AppSource[]
  refreshTokens RefreshToken[]

  @@map("users")
}

enum UserRole {
  ADMIN
  MANAGER
  VIEWER
}

model RefreshToken {
  id          String    @id @default(uuid())
  token       String    @unique
  userId      String    @map("user_id")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  revokedAt   DateTime? @map("revoked_at")
  revoked     Boolean   @default(false)
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent")

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ==========================================
// EVENT SOURCES
// ==========================================

model AppSource {
  id          String    @id @default(uuid())
  name        String
  description String?
  apiKey      String    @unique @map("api_key")
  apiKeySalt  String    @map("api_key_salt")
  isActive    Boolean   @default(true) @map("is_active")
  createdBy   String?   @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  metadata    Json? // Additional source configuration

  // Relations
  creator     User?     @relation(fields: [createdBy], references: [id])
  events      Event[]
  rules       AutomationRule[]

  @@map("app_sources")
}

// ==========================================
// EVENTS
// ==========================================

model Event {
  id              String      @id @default(uuid())
  sourceId        String      @map("source_id")
  eventType       String      @map("event_type")
  correlationId   String?     @map("correlation_id")
  payload         Json // Flexible JSON payload
  status          EventStatus @default(RECEIVED)
  receivedAt      DateTime    @default(now()) @map("received_at")
  processedAt     DateTime?   @map("processed_at")
  matchedRules    Int         @default(0) @map("matched_rules")
  
  // Idempotency check
  isDuplicate     Boolean     @default(false) @map("is_duplicate")
  originalEventId String?     @map("original_event_id")

  // Relations
  source          AppSource   @relation(fields: [sourceId], references: [id])
  executions      ActionExecution[]

  // Index for idempotency lookups
  @@index([sourceId, correlationId])
  @@index([eventType])
  @@index([status])
  @@index([receivedAt])
  @@map("events")
}

enum EventStatus {
  RECEIVED      // Initial state
  PROCESSING    // Being evaluated by rule engine
  MATCHED       // Matched with rules, actions queued
  NO_MATCH      // No rules matched
  COMPLETED     // All actions completed
  PARTIAL       // Some actions failed
  ERROR         // Processing error
}

// ==========================================
// AUTOMATION RULES
// ==========================================

model AutomationRule {
  id            String    @id @default(uuid())
  name          String
  description   String?
  sourceId      String?   @map("source_id") // null = any source
  eventType     String    @map("event_type") // e.g., "payment.failed"
  priority      Int       @default(0) // Higher = processed first
  
  // Conditions (JSON structure for flexibility)
  conditions    Json      @map("conditions_json")
  conditionText String?   @map("condition_text") // Human-readable version
  
  // Actions (JSON array)
  actions       Json      @map("actions_json")
  
  // Status
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  createdBy     String?   @map("created_by")
  
  // Statistics
  executionCount Int      @default(0) @map("execution_count")
  successCount   Int      @default(0) @map("success_count")
  failureCount   Int      @default(0) @map("failure_count")
  lastExecutedAt DateTime? @map("last_executed_at")

  // Relations
  source        AppSource? @relation(fields: [sourceId], references: [id])
  executions    ActionExecution[]

  @@index([eventType, isActive])
  @@index([sourceId, eventType])
  @@index([priority])
  @@map("automation_rules")
}

// ==========================================
// ACTION EXECUTIONS
// ==========================================

model ActionExecution {
  id              String            @id @default(uuid())
  eventId         String            @map("event_id")
  ruleId          String            @map("rule_id")
  actionIndex     Int               @map("action_index") // Which action in the rule
  actionType      ActionType        @map("action_type")
  actionConfig    Json              @map("action_config")
  
  // Execution state
  status          ExecutionStatus   @default(PENDING)
  attemptCount    Int               @default(0) @map("attempt_count")
  maxAttempts     Int               @default(3) @map("max_attempts")
  
  // Timing
  startedAt       DateTime?         @map("started_at")
  completedAt     DateTime?         @map("completed_at")
  nextRetryAt     DateTime?         @map("next_retry_at")
  lastAttemptAt   DateTime?         @map("last_attempt_at")
  
  // Error tracking
  errorMessage    String?           @map("error_message")
  errorDetails    Json?             @map("error_details")
  errorCategory   String?           @map("error_category") // NETWORK, TIMEOUT, VALIDATION, etc.
  
  // Result
  result          Json?             // Action-specific result
  responseData    Json?             @map("response_data") // For webhooks: status, body
  durationMs      Int?              @map("duration_ms")

  // Queue tracking
  jobId           String?           @map("job_id") // BullMQ job ID
  queueName       String?           @map("queue_name")

  // Timestamps
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  // Relations
  event           Event             @relation(fields: [eventId], references: [id])
  rule            AutomationRule    @relation(fields: [ruleId], references: [id])
  failure         FailedExecution? // One-to-one relation
  webhooks        WebhookDelivery[] // For webhook actions

  @@index([eventId])
  @@index([ruleId])
  @@index([status, nextRetryAt])
  @@index([createdAt])
  @@map("action_executions")
}

enum ActionType {
  SEND_EMAIL
  CALL_WEBHOOK
  CREATE_NOTIFICATION
  // Future types:
  // CREATE_TASK
  // TRIGGER_EVENT
  // DELAYED_EXECUTION
  // MULTI_WEBHOOK
}

enum ExecutionStatus {
  PENDING     // Waiting to be processed
  QUEUED      // Job added to queue
  PROCESSING  // Worker is executing
  SUCCESS     // Action completed successfully
  FAILED      // Failed, will retry
  RETRYING    // Scheduled for retry
  PERMANENTLY_FAILED // Max attempts reached, moved to dead letter
  CANCELLED   // Manually cancelled
}

// ==========================================
// FAILED EXECUTIONS (Dead Letter Queue)
// ==========================================

model FailedExecution {
  id              String    @id @default(uuid())
  executionId     String    @unique @map("execution_id")
  
  // Failure details
  finalAttemptAt  DateTime  @map("final_attempt_at")
  finalError      String    @map("final_error")
  errorCategory   String?   @map("error_category")
  stackTrace      String?   @map("stack_trace")
  
  // Classification
  failureReason   FailureReason @map("failure_reason")
  isNotified      Boolean   @default(false) @map("is_notified")
  
  // Resolution
  status          FailedStatus @default(UNRESOLVED)
  resolvedAt      DateTime? @map("resolved_at")
  resolvedBy      String?   @map("resolved_by")
  resolution      String?   // How it was resolved
  
  // Retry control
  manualRetryAt   DateTime? @map("manual_retry_at")
  manualRetryBy   String?   @map("manual_retry_by")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  execution       ActionExecution @relation(fields: [executionId], references: [id])

  @@index([status, createdAt])
  @@index([failureReason])
  @@map("failed_executions")
}

enum FailureReason {
  UNRESOLVED    // Not yet analyzed
  NETWORK_ERROR // External service unavailable
  TIMEOUT       // Request timeout
  INVALID_CONFIG // Misconfigured action
  RATE_LIMITED  // External rate limiting
  AUTH_ERROR    // Authentication/authorization failed
  VALIDATION    // Input validation failed
  UNKNOWN       // Unknown error
  FIXED         // Issue resolved
  IGNORED       // Decided not to fix
}

enum FailedStatus {
  UNRESOLVED
  UNDER_INVESTIGATION
  PENDING_FIX
  FIXED
  RETRIED_SUCCESSFULLY
  IGNORED
}

// ==========================================
// WEBHOOK DELIVERIES
// ==========================================

model WebhookDelivery {
  id              String    @id @default(uuid())
  executionId     String    @map("execution_id")
  targetUrl       String    @map("target_url")
  method          String    @default("POST")
  requestHeaders  Json?     @map("request_headers")
  requestBody     Json?     @map("request_body")
  
  // Response
  responseStatus  Int?      @map("response_status")
  responseHeaders Json?     @map("response_headers")
  responseBody    String?   @map("response_body")
  
  // Timing
  requestStartedAt  DateTime  @map("request_started_at")
  requestEndedAt    DateTime? @map("request_ended_at")
  durationMs        Int?      @map("duration_ms")
  
  // Status
  isSuccess       Boolean   @map("is_success")
  errorMessage    String?   @map("error_message")

  createdAt       DateTime  @default(now()) @map("created_at")

  // Relations
  execution       ActionExecution @relation(fields: [executionId], references: [id])

  @@index([executionId])
  @@index([isSuccess])
  @@map("webhook_deliveries")
}

// ==========================================
// AUDIT LOGGING
// ==========================================

model AuditLog {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id")
  action      AuditAction @map("action")
  entityType  String    @map("entity_type") // "rule", "source", "event", etc.
  entityId    String    @map("entity_id")
  oldValue    Json?     @map("old_value")
  newValue    Json?     @map("new_value")
  metadata    Json?     // Additional context
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  user        User?     @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXECUTE
  RETRY
  CANCEL
  ACTIVATE
  DEACTIVATE
}

// ==========================================
// METRICS (Aggregated statistics)
// ==========================================

model DailyMetrics {
  id              String    @id @default(uuid())
  date            DateTime  @unique @db.Date
  
  // Event stats
  eventsReceived  Int       @default(0) @map("events_received")
  eventsProcessed Int       @default(0) @map("events_processed")
  eventsFailed    Int       @default(0) @map("events_failed")
  
  // Execution stats
  executionsCreated   Int   @default(0) @map("executions_created")
  executionsSuccess   Int   @default(0) @map("executions_success")
  executionsFailed    Int   @default(0) @map("executions_failed")
  executionsRetried   Int   @default(0) @map("executions_retried")
  
  // Action type breakdown
  emailCount      Int       @default(0) @map("email_count")
  webhookCount    Int       @default(0) @map("webhook_count")
  notificationCount Int     @default(0) @map("notification_count")
  
  // Performance
  avgExecutionMs  Int?      @map("avg_execution_ms")
  maxExecutionMs  Int?      @map("max_execution_ms")
  
  // System
  queueDepth      Int?      @map("queue_depth")
  retryQueueDepth Int?      @map("retry_queue_depth")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("daily_metrics")
}
